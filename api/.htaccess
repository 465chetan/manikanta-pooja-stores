Options -Indexes
AddDefaultCharset UTF-8

# ── Forward Authorization header to PHP (needed for JWT tokens) ──
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
</IfModule>

# ── Block direct browser access to config & database files ──
<Files "config.php">
    Require all denied
</Files>
<Files "database.php">
    Require all denied
</Files>
